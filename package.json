{
  "name": "@nimiplatform/nimi-coding",
  "version": "0.3.0",
  "private": false,
  "description": "AI-native methodology, spec construction, and deterministic governance validation.",
  "license": "MIT",
  "homepage": "https://docs.nimi.ai/nimicoding",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nimiplatform/nimi-coding.git"
  },
  "bugs": {
    "url": "https://github.com/nimiplatform/nimi-coding/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/nimiplatform"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "nimicoding": "bin/nimicoding.mjs"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "keywords": [
    "ai",
    "coding",
    "governance",
    "methodology",
    "spec",
    "nimicoding"
  ],
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "files": [
    "bin",
    "cli",
    "config",
    "contracts",
    "methodology",
    "spec",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node ./cli/dev/run-suite.mjs",
    "check:ci": "pnpm test && pnpm check:pack && node ./cli/dev/run-cli-smoke.mjs",
    "check:pack": "npm pack --dry-run"
