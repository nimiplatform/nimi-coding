{
  "name": "@nimiplatform/nimi-coding",
  "version": "0.2.0",
  "private": false,
  "description": "AI-native coding governance toolkit for bootstrapping .nimi/** into arbitrary projects.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nimiplatform/nimi-coding.git"
  },
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "bin": {
    "nimicoding": "./bin/nimicoding.mjs"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "keywords": [
    "ai",
    "coding",
    "governance",
    "methodology",
    "spec",
    "nimicoding"
  ],
  "dependencies": {
    "@openai/codex-sdk": "^0.124.0",
    "yaml": "^2.8.1"
  },
  "files": [
    "bin",
    "cli",
    "adapters",
    "config",
    "contracts",
    "methodology",
    "spec",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "NIMICODING_LANG=en NO_COLOR=1 node --test",
    "check:pack": "npm pack --dry-run"
  }
}
